{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "types": ["@webgpu/types"],
    "paths": {
      "gamekit": ["../../packages/gamekit/src/index.ts"],
      "gamekit/renderer": ["../../packages/gamekit/src/render/index.ts"],
      "gamekit/input": ["../../packages/gamekit/src/input/index.ts"],
      "gamekit/audio": ["../../packages/gamekit/src/audio/index.ts"]
    }
  },
  "include": ["src", "vite.config.ts"]
}
