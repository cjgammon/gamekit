{
  "name": "gamekit-workspace",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "test:e2e": "bun test ./tests/**/*.test.ts",
    "test:e2e:watch": "bun test --watch ./tests/**/*.test.ts",
    "test:e2e:debug": "bun test --bail ./tests/**/*.test.ts"
  }
}