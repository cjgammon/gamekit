{
  "name": "gamekit-workspace",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "build": "npx tsc -p packages/gamekit && npx tsc -p packages/gamekit-server",
    "build:gamekit": "npx tsc -p packages/gamekit",
    "test": "bun test tests/unit/",
    "test:watch": "bun test --watch tests/unit/",
    "test:net": "npm run build:gamekit && bun test tests/net/",
    "demo:server": "npm run build && node examples/netdemo/server.mjs",
    "demo:render": "npm run build:gamekit && python3 -m http.server 8080",
    "demo:mode": "vite examples/mode",
    "test:e2e": "bun test tests/",
    "test:e2e:watch": "bun test --watch tests/",
    "test:e2e:debug": "bun test --bail tests/"
  }
}