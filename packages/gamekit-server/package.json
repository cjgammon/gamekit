{
  "name": "gamekit-server",
  "version": "0.1.0",
  "description": "Authoritative multiplayer server for gamekit — headless fixed-rate loop, from-scratch WebSocket transport, snapshot broadcast. Zero runtime dependencies.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch"
  },
  "keywords": [
    "gamekit",
    "game-server",
    "multiplayer",
    "websocket",
    "authoritative",
    "zero-dependency"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "gamekit": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^6.0.2"
  }
}