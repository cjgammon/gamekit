{
  "name": "@cjgammon/gamekit-server",
  "version": "0.1.1",
  "description": "Authoritative multiplayer server for gamekit — headless fixed-rate loop, from-scratch WebSocket transport, snapshot broadcast. Zero runtime dependencies.",
  "type": "module",
  "license": "MIT",
  "author": "CJ Gammon",
  "homepage": "https://github.com/cjgammon/gamekit#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cjgammon/gamekit.git",
    "directory": "packages/gamekit-server"
  },
  "bugs": "https://github.com/cjgammon/gamekit/issues",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepack": "tsc"
  },
  "keywords": [
    "gamekit",
    "game-server",
    "multiplayer",
    "websocket",
    "authoritative",
    "zero-dependency"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@cjgammon/gamekit": "^0.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^6.0.2"
  }
}
