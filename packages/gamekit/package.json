{
  "name": "gamekit",
  "version": "0.1.0",
  "description": "A friendly game engine for kids learning to code — PixiJS rendering, Matter.js physics, and Socket.io multiplayer in one simple package",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch"
  },
  "keywords": [
    "game-engine",
    "kids",
    "learning",
    "pixi",
    "matter-js",
    "multiplayer",
    "socket.io",
    "webgl",
    "physics"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "matter-js": "^0.19.0",
    "pixi.js": "^7.4.0",
    "socket.io-client": "^4.7.0"
  },
  "devDependencies": {
    "typescript": "^6.0.2"
  }
}
