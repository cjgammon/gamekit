{
  "name": "gamekit",
  "version": "0.1.0",
  "description": "A 2D multiplayer game engine for the web, written in TypeScript from scratch. Zero runtime dependencies, Flixel-inspired, WebGPU renderer.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./net": {
      "development": "./src/net/index.ts",
      "import": "./dist/net/index.js",
      "types": "./dist/net/index.d.ts"
    },
    "./input": {
      "development": "./src/input/index.ts",
      "import": "./dist/input/index.js",
      "types": "./dist/input/index.d.ts"
    },
    "./renderer": {
      "development": "./src/render/index.ts",
      "import": "./dist/render/index.js",
      "types": "./dist/render/index.d.ts"
    },
    "./audio": {
      "development": "./src/audio/index.ts",
      "import": "./dist/audio/index.js",
      "types": "./dist/audio/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch"
  },
  "keywords": [
    "game-engine",
    "2d",
    "multiplayer",
    "webgpu",
    "typescript",
    "flixel",
    "zero-dependency"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {},
  "devDependencies": {
    "@webgpu/types": "^0.1.70",
    "typescript": "^6.0.2"
  }
}
