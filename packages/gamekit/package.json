{
  "name": "@cjgammon/gamekit",
  "version": "0.1.1",
  "description": "A 2D multiplayer game engine for the web, written in TypeScript from scratch. Zero runtime dependencies, Flixel-inspired, WebGPU renderer.",
  "type": "module",
  "license": "MIT",
  "author": "CJ Gammon",
  "homepage": "https://github.com/cjgammon/gamekit#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cjgammon/gamekit.git",
    "directory": "packages/gamekit"
  },
  "bugs": "https://github.com/cjgammon/gamekit/issues",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./net": {
      "types": "./dist/net/index.d.ts",
      "import": "./dist/net/index.js"
    },
    "./input": {
      "types": "./dist/input/index.d.ts",
      "import": "./dist/input/index.js"
    },
    "./renderer": {
      "types": "./dist/render/index.d.ts",
      "import": "./dist/render/index.js"
    },
    "./audio": {
      "types": "./dist/audio/index.d.ts",
      "import": "./dist/audio/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepack": "tsc"
  },
  "keywords": [
    "game-engine",
    "2d",
    "multiplayer",
    "webgpu",
    "typescript",
    "flixel",
    "zero-dependency"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {},
  "devDependencies": {
    "@webgpu/types": "^0.1.70",
    "typescript": "^6.0.2"
  }
}
